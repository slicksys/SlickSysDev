@page "/appointments"
@rendermode InteractiveServer
@inject AppointmentsApiClient Api

<PageTitle>Appointments</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Scheduled Appointments</h1>
    <div>
        <button class="btn btn-outline-secondary btn-sm me-2" @onclick="LoadData">
            <span class="bi bi-arrow-clockwise"></span> Refresh
        </button>
        <span class="badge bg-info">@appointments.Count total</span>
    </div>
</div>

@if (notifications.Any(n => !n.IsRead))
{
    <div class="alert alert-warning d-flex justify-content-between align-items-center">
        <span>
            <strong>@notifications.Count(n => !n.IsRead)</strong> new appointment notification(s)
        </span>
        <button class="btn btn-sm btn-outline-warning" @onclick="MarkAllRead">Mark all read</button>
    </div>

    <div class="mb-4">
        @foreach (var n in notifications.Where(n => !n.IsRead))
        {
            <div class="alert alert-info py-2 mb-1">
                <small>@n.CreatedAt.ToString("MMM dd, h:mm tt")</small> — @n.Message
            </div>
        }
    </div>
}

@if (isLoading)
{
    <p><em>Loading appointments...</em></p>
}
else if (appointments.Count == 0)
{
    <div class="alert alert-secondary">No appointments have been scheduled yet.</div>
}
else
{
    <div class="mb-3">
        <label class="form-label me-2">Filter by status:</label>
        <select class="form-select form-select-sm d-inline-block" style="width: auto" @onchange="OnFilterChanged">
            <option value="All">All</option>
            <option value="Scheduled">Scheduled</option>
            <option value="Confirmed">Confirmed</option>
            <option value="Cancelled">Cancelled</option>
            <option value="Completed">Completed</option>
        </select>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Date &amp; Time</th>
                    <th>Client</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Service</th>
                    <th>Notes</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var appt in FilteredAppointments)
                {
                    <tr>
                        <td>@appt.ScheduledAt.ToString("MMM dd, yyyy h:mm tt")</td>
                        <td>@appt.ClientName</td>
                        <td><a href="mailto:@appt.ClientEmail">@appt.ClientEmail</a></td>
                        <td>@appt.ClientPhone</td>
                        <td>@appt.ServiceType</td>
                        <td>@(appt.Notes ?? "—")</td>
                        <td>
                            <span class="badge @GetStatusBadgeClass(appt.Status)">@appt.Status</span>
                        </td>
                        <td>
                            @if (appt.Status == "Scheduled")
                            {
                                <button class="btn btn-sm btn-success me-1" @onclick="() => Confirm(appt.Id)" title="Confirm">
                                    ✓
                                </button>
                                <button class="btn btn-sm btn-danger" @onclick="() => Cancel(appt.Id)" title="Cancel">
                                    ✕
                                </button>
                            }
                            else if (appt.Status == "Confirmed")
                            {
                                <button class="btn btn-sm btn-danger" @onclick="() => Cancel(appt.Id)" title="Cancel">
                                    ✕
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<AppointmentDto> appointments = [];
    private List<AdminNotificationDto> notifications = [];
    private bool isLoading = true;
    private string statusFilter = "All";

    private IEnumerable<AppointmentDto> FilteredAppointments =>
        statusFilter == "All"
            ? appointments
            : appointments.Where(a => a.Status == statusFilter);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            var appointmentsTask = Api.GetAllAppointmentsAsync();
            var notificationsTask = Api.GetNotificationsAsync();
            await Task.WhenAll(appointmentsTask, notificationsTask);

            appointments = appointmentsTask.Result;
            notifications = notificationsTask.Result;
        }
        catch
        {
            appointments = [];
            notifications = [];
        }
        isLoading = false;
    }

    private async Task Confirm(Guid id)
    {
        await Api.ConfirmAppointmentAsync(id);
        await LoadData();
    }

    private async Task Cancel(Guid id)
    {
        await Api.CancelAppointmentAsync(id);
        await LoadData();
    }

    private async Task MarkAllRead()
    {
        await Api.MarkAllNotificationsReadAsync();
        await LoadData();
    }

    private void OnFilterChanged(ChangeEventArgs e)
    {
        statusFilter = e.Value?.ToString() ?? "All";
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Scheduled" => "bg-primary",
        "Confirmed" => "bg-success",
        "Cancelled" => "bg-danger",
        "Completed" => "bg-secondary",
        _ => "bg-info"
    };
}
