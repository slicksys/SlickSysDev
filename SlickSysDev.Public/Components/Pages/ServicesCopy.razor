                "Penetration testing and vulnerability assessment",
            ],
            false
        ),
        new(
            "support",
            "bx bx-headphone",
            "Post-Migration Support",
            "Our engagement doesn't end at go-live. We provide structured hypercare support, knowledge transfer, and ongoing optimization to ensure your teams are confident and your systems continue to improve.",
