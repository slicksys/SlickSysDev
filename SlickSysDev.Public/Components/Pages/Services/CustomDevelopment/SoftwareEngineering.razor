<!-- How we work (Steps) -->
<section class="container pb-5 mb-md-2 mb-lg-4 mb-xl-5">
  <h2 class="h1 pb-2 pb-md-0 mb-4 mb-md-5">How We Work?</h2>
  <div class="steps steps-sm steps-horizontal-md pb-2 pb-sm-3">
    <div class="step">
      <div class="step-number">
        <div class="step-number-inner">1</div>
      </div>
      <div class="step-body">
        <h3 class="h4 mb-3">Business &amp; Architecture Discovery</h3>
        <p class="mb-0">
          We collaborate with stakeholders to understand business objectives, analyze existing systems,
          and define a scalable architecture aligned with enterprise technology platforms.
        </p>
      </div>
    </div>
    <div class="step">
      <div class="step-number">
        <div class="step-number-inner">2</div>
      </div>
      <div class="step-body">
        <h3 class="h4 mb-3">Solution Design &amp; Cloud Strategy</h3>
        <p class="mb-0">
          Our architects design secure and scalable solutions leveraging platforms such as Azure, AWS,
          Google Cloud, Salesforce, and SAP ecosystems.
        </p>
      </div>
    </div>
    <div class="step">
      <div class="step-number">
        <div class="step-number-inner">3</div>
      </div>
      <div class="step-body">
        <h3 class="h4 mb-3">Agile Development &amp; Integration</h3>
        <p class="mb-0">
          Using agile methodologies, we build robust applications, integrate enterprise systems,
          and implement APIs and microservices architectures.
        </p>
      </div>
    </div>
    <div class="step">
      <div class="step-number">
        <div class="step-number-inner">4</div>
      </div>
      <div class="step-body">
        <h3 class="h4 mb-3">Deployment, AI Enablement &amp; Optimization</h3>
        <p class="mb-0">
          We deploy solutions to production environments, implement AI and analytics capabilities,
          and continuously optimize performance, scalability, and security.
        </p>
      </div>
    </div>
  </div>
</section>

