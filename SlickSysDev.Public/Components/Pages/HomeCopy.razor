@page "/home2"

@layout MainLayout


<PageTitle>Slicksys Development | Legacy App Migration to Modern Cloud Architecture</PageTitle>

<!-- Hero -->
<section class="position-relative pt-5 bg-dark" data-bs-theme="dark">
    <div class="position-absolute top-0 start-0 w-100 h-100 bg-repeat-0 bg-position-center bg-size-cover opacity-10" style="background-image: url(@Assets["images/landing/saas-1/hero-bg.jpg"]);"></div>
    <div class="container position-relative zindex-2 pt-5 pb-md-2">
        <div class="row justify-content-center text-center pt-5 pb-4 pb-sm-5">
            <div class="col-xl-8 col-lg-9 col-md-10">
                <div class="d-inline-flex align-items-center bg-primary bg-opacity-10 border border-primary border-opacity-25 rounded-pill px-3 py-1 mb-4">
                    <i class="bx bx-cloud-upload text-primary me-2"></i>
                    <span class="text-primary fs-sm fw-semibold">Legacy Migration Specialists</span>
                </div>
                <h1 class="display-4 fw-bold mb-4">Modernize Your Legacy Systems with Confidence</h1>
                <p class="fs-xl text-light opacity-70 mb-5">Slicksys Development transforms outdated legacy applications into scalable, secure, and high-performance cloud-native solutions — without disrupting your business.</p>
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <a href="/contact" class="btn btn-primary btn-lg shadow-primary px-5">Get a Free Assessment</a>
                    <a href="/services" class="btn btn-outline-light btn-lg px-5">Our Services</a>
                </div>
            </div>
        </div>
    </div>
    <div class="d-flex position-relative zindex-2 mt-n2 overflow-hidden" style="color: #0b0f19;">
        <div class="position-relative start-50 translate-middle-x flex-shrink-0" style="width: 3788px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="3788" height="72" viewBox="0 0 3788 72"><path fill="currentColor" d="M0,0h3788.7c-525,45.1-1181.7,71.9-1894.3,71.9S525,45.1,0,0z"/></svg>
        </div>
    </div>
</section>

<!-- Hero + BG parallax -->
<section class="jarallax bg-dark min-vh-100" data-jarallax data-speed="0.4" data-bs-theme="dark">
    <span class="position-absolute top-0 start-0 w-100 h-100"
          style="background: radial-gradient(116.18% 118% at 50% 100%, rgba(99, 102, 241, 0.1) 0%, rgba(218, 70, 239, 0.05) 41.83%, rgba(241, 244, 253, 0.07) 82.52%);"></span>
    <div class="jarallax-img" style="background-image: url(@Assets["images/landing/software-agency-2/hero-bg.png"]);"></div>
    <div class="min-vh-100 d-flex flex-column py-5">

        <div class="container position-relative text-center zindex-5 pt-4 pt-md-5 pb-5 mt-auto">
            <div class="row mt-5">
                <div class="col-xl-10 mx-auto">

                    <h1 class="display-1 mb-md-4 pb-3">Modernization and <br>Migration Experts<br></h1>
                    <h2>Engineering - Development - Integration<br></h2>
                    <p class="text-body mx-auto mb-md-5 mb-4 pb-xl-2 pb-md-0 pb-sm-2 fs-5" style="max-width: 36.5rem;">
                        Building digital excellence through innovation, strategic partnerships, systems modernization, cloud
                        transformation.
                    </p>
                    <a href="#" class="btn btn-lg btn-primary shadow-primary">Trans-Modernize Your Business with SlickSys</a>
                </div>
            </div>
        </div>
        <div class="container mt-auto pb-lg-2 pb-xl-3">
            <ul class="list-unstyled d-flex align-items-start justify-content-center flex-wrap text-nowrap mt-xl-0 mt-md-n4 mt-sm-n3 mt-n2 ms-md-n4 ms-n3 mb-0 pt-lg-5 pt-md-4">
                <li class="d-flex align-items-center text-body mt-md-4 mt-sm-3 mt-2 ms-md-4 ms-3">
                    <i class="bx bx-check-circle me-2 fs-5 text-primary"></i>
                    Extensive work experience
                </li>
                <li class="d-flex align-items-center text-body mt-md-4 mt-sm-3 mt-2 ms-md-4 ms-3">
                    <i class="bx bx-check-circle me-2 fs-5 text-primary"></i>
                    Flexible working conditions
                </li>
                <li class="d-flex align-items-center text-body mt-md-4 mt-sm-3 mt-2 ms-md-4 ms-3">
                    <i class="bx bx-check-circle me-2 fs-5 text-primary"></i>
                    Large and friendly team
                </li>
            </ul>
        </div>
    </div>
</section>


<!-- Stats Bar -->
<section class="bg-dark py-4" data-bs-theme="dark">
    <div class="container">
        <div class="row row-cols-2 row-cols-md-4 g-4 text-center">
            <div class="col">
                <h3 class="display-6 fw-bold text-primary mb-1">200+</h3>
                <p class="text-light opacity-60 mb-0 fs-sm">Legacy Systems Migrated</p>
            </div>
            <div class="col">
                <h3 class="display-6 fw-bold text-primary mb-1">98%</h3>
                <p class="text-light opacity-60 mb-0 fs-sm">Client Satisfaction Rate</p>
            </div>
            <div class="col">
                <h3 class="display-6 fw-bold text-primary mb-1">15+</h3>
                <p class="text-light opacity-60 mb-0 fs-sm">Years of Experience</p>
            </div>
            <div class="col">
                <h3 class="display-6 fw-bold text-primary mb-1">50+</h3>
                <p class="text-light opacity-60 mb-0 fs-sm">Cloud Architects on Staff</p>
            </div>
        </div>
    </div>
</section>


<!-- Core Services -->
<section class="container py-5 my-md-3 my-lg-5">
    <div class="row justify-content-center text-center mb-5">
        <div class="col-lg-7">
            <h2 class="h1 mb-3">End-to-End Migration Services</h2>
            <p class="fs-lg text-muted">From assessment to deployment, we handle every phase of your legacy modernization journey.</p>
        </div>
    </div>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var service in _services)
        {
            <div class="col">
                <div class="card card-hover h-100 border-0 shadow-sm pt-5 px-4 pb-4 position-relative">
                    <div class="d-inline-block bg-primary shadow-primary rounded-3 position-absolute top-0 translate-middle-y p-3">
                        <i class="@service.Icon text-white" style="font-size: 1.75rem;"></i>
                    </div>
                    <h3 class="h5 mt-2 mb-2">@service.Title</h3>
                    <p class="fs-sm text-muted mb-3">@service.Description</p>
                    <a href="/services" class="btn btn-link btn-sm p-0 mt-auto">
                        Learn more <i class="bx bx-right-arrow-circle ms-1"></i>
                    </a>
                </div>
            </div>
        }
    </div>
    <div class="text-center mt-5">
        <a href="/services" class="btn btn-outline-primary btn-lg px-5">View All Services</a>
    </div>
</section>


<!-- Why Choose Us -->
<section class="bg-secondary py-5">
    <div class="container py-md-3 py-lg-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-5">
                <h2 class="h1 mb-4">Why Companies Trust Slicksys</h2>
                <p class="fs-lg text-muted mb-4">We don't just lift and shift — we re-architect your systems for the cloud era, ensuring performance, security, and long-term maintainability.</p>
                <ul class="list-unstyled mb-5">
                    @foreach (var point in _whyUs)
                    {
                        <li class="d-flex align-items-start mb-3">
                            <div class="d-flex align-items-center justify-content-center bg-primary rounded-circle flex-shrink-0 mt-1" style="width: 28px; height: 28px;">
                                <i class="bx bx-check text-white fs-sm"></i>
                            </div>
                            <span class="ms-3 fs-sm">@point</span>
                        </li>
                    }
                </ul>
                <a href="/about" class="btn btn-primary px-5">About Our Team</a>
            </div>
            <div class="col-lg-6 offset-lg-1">
                <div class="row row-cols-2 g-3">
                    @foreach (var metric in _metrics)
                    {
                        <div class="col">
                            <div class="card border-0 shadow-sm h-100 p-4">
                                <i class="@metric.Icon text-primary mb-3" style="font-size: 2rem;"></i>
                                <h4 class="h6 mb-1">@metric.Title</h4>
                                <p class="fs-xs text-muted mb-0">@metric.Description</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>


<!-- Migration Process -->
<section class="container py-5 my-md-3 my-lg-5">
    <div class="row justify-content-center text-center mb-5">
        <div class="col-lg-7">
            <h2 class="h1 mb-3">Our Proven Migration Process</h2>
            <p class="fs-lg text-muted">A structured, low-risk approach that keeps your business running while we modernize your stack.</p>
        </div>
    </div>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4">
        @foreach (var (step, index) in _steps.Select((s, i) => (s, i + 1)))
        {
            <div class="col">
                <div class="card border-0 shadow-sm h-100 p-4 text-center">
                    <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 rounded-circle mx-auto mb-3" style="width: 56px; height: 56px;">
                        <span class="fw-bold text-primary fs-4">@index</span>
                    </div>
                    <h4 class="h6 mb-2">@step.Title</h4>
                    <p class="fs-xs text-muted mb-0">@step.Description</p>
                </div>
            </div>
        }
    </div>
</section>


<!-- Technologies -->
<section class="bg-secondary py-5">
    <div class="container py-md-3">
        <div class="row justify-content-center text-center mb-5">
            <div class="col-lg-7">
                <h2 class="h1 mb-3">Cloud Platforms &amp; Technologies</h2>
                <p class="fs-lg text-muted">We work with the leading cloud providers and modern frameworks to deliver future-proof solutions.</p>
            </div>
        </div>
        <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-6 g-3 justify-content-center">
            @foreach (var tech in _technologies)
            {
                <div class="col">
                    <div class="card border-0 shadow-sm h-100 p-3 text-center">
                        <i class="@tech.Icon text-primary mx-auto mb-2" style="font-size: 2.25rem;"></i>
                        <p class="fs-xs fw-semibold mb-0">@tech.Name</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>


<!-- Testimonials -->
<section class="container py-5 my-md-3 my-lg-5">
    <div class="row justify-content-center text-center mb-5">
        <div class="col-lg-7">
            <h2 class="h1 mb-3">What Our Clients Say</h2>
            <p class="fs-lg text-muted">Real results from companies that trusted us with their most critical systems.</p>
        </div>
    </div>
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var testimonial in _testimonials)
        {
            <div class="col">
                <div class="card border-0 shadow-sm h-100 p-4 p-xl-5">
                    <div class="d-flex mb-3">
                        @for (int i = 0; i < 5; i++)
                        {
                            <i class="bx bxs-star text-warning me-1"></i>
                        }
                    </div>
                    <blockquote class="mb-4">
                        <p class="fs-sm mb-0">"@testimonial.Quote"</p>
                    </blockquote>
                    <div class="d-flex align-items-center mt-auto">
                        <div class="d-flex align-items-center justify-content-center bg-primary rounded-circle text-white fw-bold flex-shrink-0" style="width: 44px; height: 44px; font-size: 1rem;">
                            @testimonial.Initials
                        </div>
                        <div class="ms-3">
                            <h6 class="fw-semibold mb-0">@testimonial.Name</h6>
                            <span class="fs-xs text-muted">@testimonial.Role</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>


<!-- CTA -->
<section class="bg-primary py-5" data-bs-theme="dark">
    <div class="container py-md-3 py-lg-4 text-center">
        <h2 class="h1 text-white mb-3">Ready to Modernize Your Legacy Systems?</h2>
        <p class="fs-lg text-white opacity-70 mb-5 mx-auto" style="max-width: 600px;">Schedule a free technical assessment with our cloud architects and get a clear migration roadmap tailored to your business.</p>
        <div class="d-flex flex-wrap justify-content-center gap-3">
            <a href="/contact" class="btn btn-light btn-lg shadow px-5">Get Free Assessment</a>
            <a href="/pricing" class="btn btn-outline-light btn-lg px-5">View Pricing</a>
        </div>
    </div>
</section>


@code {
    private record ServiceItem(string Icon, string Title, string Description);
    private record MetricItem(string Icon, string Title, string Description);
    private record StepItem(string Title, string Description);
    private record TechItem(string Icon, string Name);
    private record TestimonialItem(string Quote, string Name, string Role, string Initials);

    private readonly List<ServiceItem> _services = new()
    {
        new("bx bx-transfer-alt", "Legacy Assessment & Strategy", "Deep-dive analysis of your existing systems to identify risks, dependencies, and the optimal migration path to the cloud."),
        new("bx bx-cloud-upload", "Cloud Migration & Lift-Shift", "Seamless migration of on-premise workloads to AWS, Azure, or GCP with minimal downtime and zero data loss."),
        new("bx bx-code-block", "Application Re-Architecture", "Transform monolithic legacy apps into microservices and cloud-native architectures built for scale and resilience."),
        new("bx bx-data", "Database Modernization", "Migrate legacy databases to managed cloud services, improving performance, reliability, and reducing operational overhead."),
        new("bx bx-shield-quarter", "Security & Compliance", "Embed security best practices and compliance frameworks (SOC 2, HIPAA, PCI-DSS) throughout the migration lifecycle."),
        new("bx bx-support", "Managed Post-Migration Support", "Ongoing monitoring, optimization, and support to ensure your modernized systems perform at their peak after go-live."),
    };

    private readonly List<string> _whyUs = new()
    {
        "Zero-downtime migration strategies that keep your business running",
        "Dedicated cloud architects with 15+ years of enterprise experience",
        "Transparent fixed-price engagements with no hidden costs",
        "Proven methodology used across 200+ successful migrations",
        "Full knowledge transfer so your team owns the new system",
        "Post-migration SLA guarantees and 24/7 support options",
    };

    private readonly List<MetricItem> _metrics = new()
    {
        new("bx bx-time-five", "Avg. 40% Faster Delivery", "Compared to in-house migration attempts"),
        new("bx bx-trending-down", "60% Cost Reduction", "In infrastructure and maintenance costs"),
        new("bx bx-shield-quarter", "Zero Data Loss", "Guaranteed across all migration engagements"),
        new("bx bx-rocket", "3x Performance Gains", "Average improvement in application throughput"),
    };

    private readonly List<StepItem> _steps = new()
    {
        new("Discovery & Assessment", "We audit your legacy systems, document dependencies, and identify migration risks and opportunities."),
        new("Migration Blueprint", "Our architects design a detailed cloud architecture and phased migration plan tailored to your goals."),
        new("Iterative Migration", "We migrate in controlled sprints, validating each phase before proceeding to minimize risk."),
        new("Optimize & Handover", "Post-migration tuning, documentation, and team training to ensure long-term success."),
    };

    private readonly List<TechItem> _technologies = new()
    {
        new("bx bxl-microsoft", "Azure"),
        new("bx bxl-amazon", "AWS"),
        new("bx bxl-google-cloud", "Google Cloud"),
        new("bx bxl-docker", "Docker"),
        new("bx bxl-kubernetes", "Kubernetes"),
        new("bx bxl-net-framework", ".NET"),
        new("bx bxl-nodejs", "Node.js"),
        new("bx bxl-react", "React"),
        new("bx bxl-postgresql", "PostgreSQL"),
        new("bx bxl-mongodb", "MongoDB"),
        new("bx bxl-github", "GitHub Actions"),
        new("bx bx-data", "Terraform"),
    };

    private readonly List<TestimonialItem> _testimonials = new()
    {
        new("Slicksys migrated our 20-year-old ERP system to Azure in just 4 months. Zero downtime, zero data loss. Our infrastructure costs dropped by 55% in the first year.", "Marcus Chen", "CTO, Meridian Manufacturing", "MC"),
        new("We had tried twice before with other vendors and failed. Slicksys came in, assessed the real blockers, and delivered a flawless migration. Highly recommend.", "Sarah Okafor", "VP Engineering, FinBridge Corp", "SO"),
        new("The team's expertise in .NET modernization is unmatched. They re-architected our legacy monolith into microservices and our deployment frequency went from monthly to daily.", "James Whitfield", "Director of IT, HealthTrack Systems", "JW"),
    };
}

