@page "/products"

@layout MainLayout

<PageTitle>Products | Slicksys Development</PageTitle>

<section class="container my-5 py-lg-5 py-md-4 pt-2 pb-3">
  <h1 class="h2 mb-4 text-center">Products</h1>
  <p class="text-center text-body-secondary mb-5">Explore our offerings. This is placeholder content using existing theme styles.</p>

  <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
    @for (var i = 1; i <= 6; i++)
    {
      <div class="col">
        <div class="card h-100 shadow-sm card-hover">
          <img src="@Assets["images/landing/software-agency-2/case-studies/01.jpg"]" class="card-img-top" alt="Product image">
          <div class="card-body d-flex flex-column">
            <h3 class="h5">Product @i</h3>
            <p class="text-body-secondary mb-4">Short description for product @i using theme utilities.</p>
            <div class="mt-auto d-flex align-items-center justify-content-between">
              <span class="fw-semibold">$99</span>
              <a href="#" class="btn btn-primary btn-sm">Learn more</a>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
</section>

