@page "/bio"
@layout MainLayout

<PageTitle>Bio | Slicksys Development</PageTitle>

<section class="container my-5 py-lg-5 py-md-4 pt-2 pb-3">
  <div class="row align-items-center g-4 g-lg-5">
    <div class="col-12 col-lg-8">
      <h1 class="display-5 mb-3">C. Lane</h1>
      <p class="fs-lg text-body-secondary mb-4">Engineering leader and solutions architect with extensive experience in modernization, cloud migration, and enterprise integrations.</p>
      <div class="d-flex flex-wrap gap-3">
        <a class="btn btn-primary" href="@Assets["docs/resume.pdf"]" target="_blank" rel="noopener">Download Resume</a>
        <a class="btn btn-outline-primary" href="/contact">Contact</a>
      </div>
    </div>
    <div class="col-12 col-lg-4 text-center">
      <img src="@Assets["images/landing/software-agency-2/awards/clutch.png"]" class="img-fluid rounded" alt="Profile placeholder" style="max-width: 220px;">
    </div>
  </div>
</section>

<section class="container pb-5">
  <div class="row g-4">
    <div class="col-12 col-lg-6">
      <h2 class="h4 mb-3">About</h2>
      <p>Seasoned technologist focused on delivering business impact through pragmatic architecture, high-leverage platforms, and collaborative execution.</p>
      <p>Experienced across Azure, .NET, modern frontends, distributed systems, and data platforms.</p>
      <p>Comfortable leading from 0?1 and 1?N, with a bias for measurable outcomes.</p>
    </div>
    <div class="col-12 col-lg-6">
      <h2 class="h4 mb-3">Skills</h2>
      <div class="d-flex flex-wrap gap-2">
        <span class="badge bg-secondary">.NET</span>
        <span class="badge bg-secondary">C#</span>
        <span class="badge bg-secondary">Azure</span>
        <span class="badge bg-secondary">Containers</span>
        <span class="badge bg-secondary">CI/CD</span>
        <span class="badge bg-secondary">Architecture</span>
      </div>
    </div>
  </div>
</section>

<section class="container pb-5">
  <h2 class="h4 mb-4">Experience</h2>
  <div class="row g-4">
    <div class="col-12">
      <div class="card shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between flex-wrap gap-2">
            <h3 class="h5 mb-1">Principal Engineer / Architect</h3>
            <span class="text-body-secondary">YYYY – Present</span>
          </div>
          <div class="text-body-secondary">Slicksys Development Inc.</div>
          <ul class="mt-3 mb-0">
            <li>Led modernization initiatives and complex cloud migrations.</li>
            <li>Shipped high-impact features across services and UX.</li>
            <li>Partnered with stakeholders to align tech with business outcomes.</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="container pb-5">
  <h2 class="h4 mb-4">Education & Certifications</h2>
  <ul class="mb-0">
    <li>Details from resume (placeholder).</li>
  </ul>
</section>




